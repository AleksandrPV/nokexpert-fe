{
  "name": "nokexpert",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/frontend",
    "apps/backend"
  ],
  "scripts": {
    "dev": "concurrently -n front,back -c cyan,yellow \"npm run start --workspace=apps/frontend\" \"npm run start:dev --workspace=apps/backend\"",
    "frontend": "npm run start --workspace=apps/frontend",
    "backend": "npm run start:dev --workspace=apps/backend",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "build:backend": "npm run build --workspace=apps/backend",
    "lint:frontend": "npm run lint --workspace=apps/frontend",
    "lint:backend": "npm run lint --workspace=apps/backend",
    "test:frontend": "npm run test --workspace=apps/frontend",
    "test:backend": "npm run test --workspace=apps/backend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
